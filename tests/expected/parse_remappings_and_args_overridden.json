{
  "launch_file": "<TEST_WS>/src/test_nodes/launch/remappings_and_args.launch.py",
  "launch_arguments": {
    "node_name": "custom_node",
    "input_topic": "/custom_input"
  },
  "declared_arguments": {
    "node_name": {
      "default": "default_node",
      "description": "Name for the node"
    },
    "input_topic": {
      "default": "/default_input",
      "description": "Input topic to remap"
    }
  },
  "nodes": [
    {
      "type": "node",
      "package": "test_nodes",
      "executable": "node_a",
      "name": "custom_node",
      "namespace": "/test_ns",
      "fully_qualified_name": "/test_ns/custom_node",
      "remappings": [
        ["input", "/custom_input"],
        ["output", "/global_output"]
      ],
      "parameter_sources": [],
      "parameters": {},
      "cmd": ["ros2", "run", "test_nodes", "node_a", "--ros-args", "-r", "__node:=custom_node", "-r", "__ns:=/test_ns", "-r", "input:=/custom_input", "-r", "output:=/global_output"],
      "source_file": "<TEST_WS>/src/test_nodes/launch/remappings_and_args.launch.py"
    }
  ],
  "includes": []
}
